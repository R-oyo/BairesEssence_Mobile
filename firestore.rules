rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Experiencias — lectura pública, escritura solo desde admin (consola)
    match /servicios/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Favoritos — cada usuario lee y escribe solo los suyos
    match /favoritos/{docId} {
      allow read, delete: if request.auth != null
                          && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
    }

    // Perfil de usuario — cada uno lee/edita el suyo; admin lee todos
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;

      match /familia/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      match /itinerary/{docId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Reservas — turista ve las suyas; admin y seller ven todas
    match /reservas/{docId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'seller']
      );
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'seller'] ||
        (resource.data.userId == request.auth.uid && resource.data.estado == 'pendiente')
      );
      allow delete: if false;

      match /mensajes/{msgId} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/reservas/$(docId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'seller']
        );
        allow create: if request.auth != null
          && request.resource.data.senderId == request.auth.uid
          && (
            get(/databases/$(database)/documents/reservas/$(docId)).data.userId == request.auth.uid ||
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'seller']
          );
        allow update, delete: if false;
      }
    }

    // Reseñas — crear autenticado, lectura pública
    match /reviews/{docId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }
  }
}
